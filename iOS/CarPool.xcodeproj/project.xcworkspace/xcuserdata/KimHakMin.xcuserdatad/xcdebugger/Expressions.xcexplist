<?xml version="1.0" encoding="UTF-8"?>
<VariablesViewState
   version = "1.0">
   <ContextStates>
      <ContextState
         contextName = "-[LoginViewController btnFacebookLoginClick:]:LoginViewController.m">
         <PersistentStrings>
