	        android:background="@drawable/image5" >
	
	    </RelativeLayout>
	    
	    <RelativeLayout
	        android:id="@+id/rlLogo_View6"
	        android:layout_width="fill_parent"
	        android:layout_height="fill_parent"
	        android:background="@drawable/image6" >	        
	
	    </RelativeLayout>
        
    </ViewFlipper>

    <ImageView
