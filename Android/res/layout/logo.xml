        android:layout_height="fill_parent" >
        
        <RelativeLayout
            android:id="@+id/rlLogo_View1"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:background="@drawable/image1" >           
	
	    </RelativeLayout>
	    
	    <RelativeLayout
	        android:id="@+id/rlLogo_View2"
	        android:layout_width="fill_parent"
