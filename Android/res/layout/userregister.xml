<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/llUserRegisterLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".UserRegisterActivity" >

    <RelativeLayout
        android:layout_width="480px"
        android:layout_height="75px"
        android:background="@drawable/titleback" >
        
        <Button
            android:id="@+id/btnUserRegister_Back"
            android:layout_width="40px"
            android:layout_height="40px"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="12px"
            android:layout_marginTop="16px"
            android:background="@drawable/back" />
        
        <TextView
            android:id="@+id/lblUserRegister_Title"
            android:layout_width="190px"
            android:layout_height="44px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="@string/UserRegister_Title"
            android:textColor="@color/light_blue"
            android:textSize="32px" />

    </RelativeLayout>

    <ImageView
        android:id="@+id/imgUserRegister_Photo"
        android:layout_width="160px"
        android:layout_height="160px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="35px"
        android:layout_marginTop="105px"
        android:src="@drawable/defaultphoto" />

    <RelativeLayout
        android:id="@+id/relativeLayout1"
        android:layout_width="240px"
        android:layout_height="70px"
        android:layout_alignTop="@+id/imgUserRegister_Photo"
        android:layout_marginLeft="20px"
        android:layout_toRightOf="@+id/imgUserRegister_Photo"
        android:background="@drawable/grayback" >

        <ImageView
            android:id="@+id/imgUserRegister_Nickname"
            android:layout_width="32px"
            android:layout_height="42px"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_marginLeft="15px"
            android:layout_marginTop="13px"
            android:src="@drawable/profile" />

        <EditText
            android:id="@+id/txtUserRegister_Nickname"
            android:layout_width="160px"
            android:layout_height="42px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:layout_toRightOf="@+id/imgUserRegister_Nickname"
            android:background="@color/light_gray"
            android:gravity="left|center_vertical"
            android:hint="@string/UserRegister_NicknameHint"
            android:singleLine="true"
            android:textColor="@color/dark_gray"
            android:textSize="24px" />

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="240px"
        android:layout_height="70px"
        android:layout_alignBottom="@+id/imgUserRegister_Photo"
        android:layout_alignLeft="@+id/relativeLayout1"
        android:layout_marginTop="20px"
        android:background="@drawable/grayback" >

        <ImageView
            android:id="@+id/imgUserRegister_Gender"
            android:layout_width="32px"
            android:layout_height="42px"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:src="@drawable/gender" />

        <Spinner
            android:id="@+id/spinUserRegister_Gender"
            android:layout_width="170px"
            android:layout_height="55px"
            android:layout_centerVertical="true"
            android:layout_marginLeft="60px"
            android:background="@color/light_gray"
            android:prompt="@string/UserRegister_GenderHint" />
        
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/relativeLayout2"
        android:layout_width="420px"
        android:layout_height="70px"
        android:layout_alignLeft="@+id/imgUserRegister_Photo"
        android:layout_alignParentTop="true"
        android:layout_marginTop="280px"
        android:background="@drawable/grayback_long" >

        <ImageView
            android:id="@+id/imgUserRegister_Birth"
            android:layout_width="33px"
            android:layout_height="25px"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:src="@drawable/profile" />
        
        <Spinner
            android:id="@+id/spinUserRegister_YearOfBirth"
            android:layout_width="350px"
            android:layout_height="55px"
            android:layout_centerVertical="true"
            android:layout_marginLeft="60px"
            android:background="@color/light_gray"
            android:prompt="@string/UserRegister_BirthHint" />
        
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/relativeLayout3"
        android:layout_width="420px"
        android:layout_height="70px"
        android:layout_alignLeft="@+id/relativeLayout2"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="0px"
        android:layout_marginTop="365px"
        android:background="@drawable/grayback_long" >

        <EditText
            android:id="@+id/txtUserRegister_Email"
            android:layout_width="340px"
            android:layout_height="42px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:layout_toRightOf="@+id/imgUserRegister_Email"
            android:background="@color/light_gray"
            android:gravity="left|center_vertical"
            android:hint="@string/UserProfile_EmailHint"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:textColor="@color/dark_gray"
            android:textSize="24px" />

        <ImageView
            android:id="@+id/imgUserRegister_Email"
            android:layout_width="33px"
            android:layout_height="25px"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:src="@drawable/email" />

    </RelativeLayout>
    
    <RelativeLayout
        android:id="@+id/relativeLayout4"
        android:layout_width="420px"
        android:layout_height="70px"
        android:layout_alignLeft="@+id/relativeLayout3"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="0px"
        android:layout_marginTop="450px"
        android:background="@drawable/grayback_long" >

        <EditText
            android:id="@+id/txtUserRegister_PhoneNumber"
            android:layout_width="340px"
            android:layout_height="42px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="20px"
            android:layout_toRightOf="@+id/imgUserRegister_PhoneNumber"
            android:background="@color/light_gray"
            android:gravity="left|center_vertical"
            android:hint="@string/UserProfile_PhoneNumberHint"
            android:inputType="phone"
            android:singleLine="true"
            android:digits="+-1234567890()"
            android:textColor="@color/dark_gray"
            android:textSize="24px" />

        <ImageView
            android:id="@+id/imgUserRegister_PhoneNumber"
            android:layout_width="20px"
            android:layout_height="35px"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="23px"
            android:src="@drawable/phone" />

    </RelativeLayout>
    
    <RelativeLayout
        android:id="@+id/relativeLayout5"
        android:layout_width="420px"
        android:layout_height="70px"
        android:layout_alignLeft="@+id/relativeLayout4"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="0px"
        android:layout_marginTop="535px"
        android:background="@drawable/grayback_long" >

        <EditText
            android:id="@+id/txtUserRegister_Password"
            android:layout_width="340px"
            android:layout_height="42px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:layout_toRightOf="@+id/imgUserRegister_Password"
            android:background="@color/light_gray"
            android:gravity="left|center_vertical"
            android:hint="@string/UserRegister_PasswordHint"
            android:password="true"
            android:singleLine="true"
            android:textColor="@color/dark_gray"
            android:textSize="24px" />

        <ImageView
            android:id="@+id/imgUserRegister_Password"
            android:layout_width="28px"
            android:layout_height="28px"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="20px"
            android:src="@drawable/key" />

    </RelativeLayout>
    
    <RelativeLayout
        android:id="@+id/relativeLayout6"
        android:layout_width="420px"
        android:layout_height="70px"
        android:layout_alignLeft="@+id/relativeLayout5"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="0px"
        android:layout_marginTop="620px"
        android:background="@drawable/grayback_long" >

        <EditText
            android:id="@+id/txtUserRegister_RePassword"
            android:layout_width="340px"
            android:layout_height="42px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:layout_toRightOf="@+id/imgUserRegister_RePassword"
            android:background="@color/light_gray"
            android:gravity="left|center_vertical"
            android:hint="@string/UserRegister_RePasswordHint"
            android:password="true"
            android:singleLine="true"
            android:textColor="@color/dark_gray"
            android:textSize="24px" />

        <ImageView
            android:id="@+id/imgUserRegister_RePassword"
            android:layout_width="28px"
            android:layout_height="28px"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="20px"
            android:src="@drawable/key" />

    </RelativeLayout>

    <Button
        android:id="@+id/btnUserRegister_Register"
        android:layout_width="420px"
        android:layout_height="70px"
        android:layout_alignLeft="@+id/relativeLayout6"
        android:layout_alignParentTop="true"
        android:layout_marginTop="705px"
        android:background="@drawable/bluebutton"
        android:text="@string/UserRegister_Register"
        android:textColor="@color/white"
        android:textSize="28px" />

</RelativeLayout>