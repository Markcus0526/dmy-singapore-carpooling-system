<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llHistoryItemLayout"
    android:layout_width="450px"
    android:layout_height="70px"
    android:background="@color/white" >

    <TextView
        android:id="@+id/lblHistoryItem_Time"
        android:layout_width="200px"
        android:layout_height="35px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="14px"
        android:ellipsize="end"
        android:gravity="left|center_vertical"
        android:textColor="@color/dark_gray"
        android:textSize="20px" />

    <TextView
        android:id="@+id/lblHistoryItem_Name"
        android:layout_width="200px"
        android:layout_height="35px"
        android:layout_alignLeft="@+id/lblHistoryItem_Time"
        android:layout_below="@+id/lblHistoryItem_Time"
        android:ellipsize="end"
        android:gravity="left|center_vertical"
        android:singleLine="true"
        android:textColor="@color/dark_gray"
        android:textSize="20px" />

    <TextView
        android:id="@+id/lblHistoryItem_Rating"
        android:layout_width="60px"
        android:layout_height="35px"
        android:layout_centerVertical="true"
        android:layout_marginLeft="15px"
        android:layout_toRightOf="@+id/lblHistoryItem_Time"
        android:gravity="center"
        android:textColor="@color/light_blue"
        android:textSize="28px" />

    <Button
        android:id="@+id/btnHistoryItem_Rating"
        android:layout_width="135px"
        android:layout_height="50px"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginRight="10px"
        android:background="@drawable/bluebutton"
        android:textColor="@color/white"
        android:textSize="24px" />

</RelativeLayout>