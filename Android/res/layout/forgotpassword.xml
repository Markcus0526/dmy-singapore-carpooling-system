<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/llForgotPasswordLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/white"
    android:orientation="vertical" >

    <RelativeLayout
        android:layout_width="480px"
        android:layout_height="75px"
        android:background="@drawable/titleback" >
        
        <TextView
            android:id="@+id/lblForgotPassword_Title"
            android:layout_width="260px"
            android:layout_height="44px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="@string/ForgotPassword_Title"
            android:textColor="@color/light_blue"
            android:textSize="32px" />

    </RelativeLayout>
  
    <RelativeLayout
        android:id="@+id/relativeLayout1"
        android:layout_width="420px"
        android:layout_height="70px"
		android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="35px"
        android:layout_marginTop="135px"
        android:background="@drawable/grayback_long" >

        <EditText
            android:id="@+id/txtForgotPassword_Email"
            android:layout_width="340px"
            android:layout_height="42px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15px"
            android:layout_toRightOf="@+id/imgForgotPassword_Email"
            android:background="@color/light_gray"
            android:gravity="left|center_vertical"
            android:hint="@string/ForgotPassword_EmailAccountHint"
            android:singleLine="true"
            android:textColor="@color/dark_gray"
            android:textSize="24px" />

        <ImageView
            android:id="@+id/imgForgotPassword_Email"
            android:layout_width="33px"
            android:layout_height="25px"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="20px"
            android:src="@drawable/email" />

    </RelativeLayout>    

    <Button
        android:id="@+id/btnForgotPassword_ResetPassword"
        android:layout_width="420px"
        android:layout_height="70px"
        android:layout_alignLeft="@+id/relativeLayout1"
        android:layout_alignParentTop="true"
        android:layout_marginTop="705px"
        android:background="@drawable/bluebutton"
        android:text="@string/ForgotPassword_ResetPassword"
        android:textColor="@color/white"
        android:textSize="28px" />

</RelativeLayout>