<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llFindItemsLayout"
    android:layout_width="fill_parent"
    android:layout_height="80px">

    <ImageView
        android:id="@+id/imgBuildingMark"
        android:layout_width="30px"
        android:layout_height="27px"
        android:layout_centerVertical="true"
        android:layout_marginLeft="15px"
        android:scaleType="fitCenter"
        android:src="@drawable/buildmark" />

    <TextView
        android:id="@+id/txtBuildingName"
        android:layout_width="385px"
        android:layout_height="40px"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="20px"
        android:layout_toRightOf="@+id/imgBuildingMark"
        android:ellipsize="end"
        android:gravity="bottom|left"
        android:singleLine="true"
        android:text="TextView"
        android:textColor="@color/light_green"
        android:textSize="26px" />

    <TextView
        android:id="@+id/txtBuildingVicinity"
        android:layout_width="385px"
        android:layout_height="40px"
        android:layout_alignLeft="@+id/txtBuildingName"
        android:layout_below="@+id/txtBuildingName"
        android:ellipsize="end"
        android:gravity="left|center_vertical"
        android:singleLine="true"
        android:text="TextView"
        android:textColor="@color/dark_gray"
        android:textSize="20px" />

</RelativeLayout>