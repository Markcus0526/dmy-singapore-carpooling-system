<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/llAboutOtherPartyLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/white"
    android:orientation="vertical" >

     <RelativeLayout
        android:id="@+id/relativeLayout1"
        android:layout_width="480px"
        android:layout_height="73px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        android:background="@drawable/titleback" >

        <Button
            android:id="@+id/btnAboutOtherParty_Setting"
            android:layout_width="64px"
            android:layout_height="52px"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_marginLeft="12px"
            android:layout_marginTop="12px"
            android:background="@drawable/settingbutton" />

        <ImageView
            android:id="@+id/imgAboutOtherParty_Taxi"
            android:layout_width="136px"
            android:layout_height="44px"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:src="@drawable/taxi" />

    </RelativeLayout>

	 <RelativeLayout
        android:id="@+id/relativeLayout2"
        android:layout_width="420px"
        android:layout_height="490px"
        android:layout_marginLeft="30px"
        android:layout_marginTop="110px"
        android:background="@drawable/subback" >

	     <TextView
	         android:id="@+id/lblAboutOtherParty_Data"
	         android:layout_width="360px"
	         android:layout_height="440px"
	         android:layout_alignParentLeft="true"
	         android:layout_alignParentTop="true"
	         android:layout_marginLeft="25px"
	         android:layout_marginTop="25px"
	         android:gravity="top|left"
	         android:textColor="@color/dark_gray"
	         android:textSize="24px" />
	
	</RelativeLayout>

	 <Button
	     android:id="@+id/btnAboutOtherParty_Ok"
	     android:layout_width="420px"
	     android:layout_height="60px"
	     android:layout_alignLeft="@+id/relativeLayout2"
	     android:layout_below="@+id/relativeLayout2"
	     android:layout_marginTop="130px"
	     android:background="@drawable/bluebutton"
	     android:text="@string/AboutOtherParty_NextBoard"
	     android:textColor="@color/white"
	     android:textSize="28px" />

	 <TextView
	     android:id="@+id/lblAboutOtherParty"
	     android:layout_width="410px"
	     android:layout_height="85px"
	     android:layout_alignLeft="@+id/relativeLayout2"
	     android:layout_below="@+id/relativeLayout2"
	     android:layout_marginTop="20px"
	     android:gravity="left|center_vertical"
	     android:text="@string/AboutOtherParty_Hint"
	     android:textColor="@color/gray"
	     android:textSize="16px" />

</RelativeLayout>